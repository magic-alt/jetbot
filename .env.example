# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LLM_TIMEOUT_S=60
MODEL_MAX_TOKENS=128000

# ── Multi-model routing (P3) ─────────────────────────────────────────────────
# Format: provider:model (e.g. openai:gpt-4.1, anthropic:claude-sonnet-4-20250514)
LLM_DEFAULT_MODEL=
LLM_EXTRACTION_MODEL=
LLM_REPORT_MODEL=
ANTHROPIC_API_KEY=

# ── RAG (P3) ──────────────────────────────────────────────────────────────────
# token_overlap (default) | embedding | hybrid
RAG_MODE=token_overlap
# auto = detect from document language; or specify a HuggingFace model name
EMBEDDING_MODEL=auto

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=financial-report-agent

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=data
# local (default) | postgres
STORAGE_BACKEND=local
DATABASE_URL=

# ── S3/MinIO object storage (P4) ─────────────────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=jetbot-pdfs
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Task queue (P4) ──────────────────────────────────────────────────────────
# background (default) | celery
TASK_BACKEND=background
CELERY_BROKER_URL=redis://localhost:6379/0

# ── API security ──────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys (leave blank to disable auth)
API_KEYS=
CORS_ORIGINS=*

# ── Rate limiting (requests per minute per IP) ────────────────────────────────
RATE_LIMIT_UPLOAD=5
RATE_LIMIT_ANALYZE=10
RATE_LIMIT_READ=60

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100

# ── Pipeline timeouts ────────────────────────────────────────────────────────
NODE_TIMEOUT_S=120

# ── Debug & observability ─────────────────────────────────────────────────────
# Set to 1 to save intermediate extraction outputs and render page images
DEBUG=0
