# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OLLAMA_BASE_URL=http://localhost:11434/v1
LLM_TIMEOUT_S=60
MODEL_MAX_TOKENS=128000

# ── Multi-model routing (P3) ─────────────────────────────────────────────────
# Format: provider:model (e.g. openai:gpt-4.1, deepseek:deepseek-chat, ollama:qwen2.5, anthropic:claude-sonnet-4-20250514)
LLM_DEFAULT_MODEL=
LLM_EXTRACTION_MODEL=
LLM_REPORT_MODEL=
LLM_DEEP_ANALYSIS_MODEL=
DEEP_ANALYSIS_CONTEXT_TOKENS=12000
ANTHROPIC_API_KEY=

# ── External Hermes agent (optional) ─────────────────────────────────────────
HERMES_AGENT_URL=
HERMES_AGENT_API_KEY=
HERMES_AGENT_MODEL=hermes-agent
HERMES_AGENT_TIMEOUT_S=60

# ── RAG (P3) ──────────────────────────────────────────────────────────────────
# token_overlap (default) | embedding | hybrid
RAG_MODE=token_overlap
# auto = detect from document language; or specify a HuggingFace model name
EMBEDDING_MODEL=auto

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=financial-report-agent

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=data
# local (default) | postgres
STORAGE_BACKEND=local
DATABASE_URL=

# ── S3/MinIO object storage (P4) ─────────────────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=jetbot-pdfs
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Task queue (P4) ──────────────────────────────────────────────────────────
# background (default) | celery
TASK_BACKEND=background
CELERY_BROKER_URL=redis://localhost:6379/0

# ── API security ──────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys (leave blank to disable auth)
API_KEYS=
CORS_ORIGINS=*

# ── Docker host port overrides (optional) ───────────────────────────────────
# Only needed when local ports such as 8000 or 6379 are already occupied.

# ── Rate limiting (requests per minute per IP) ────────────────────────────────
RATE_LIMIT_UPLOAD=5
RATE_LIMIT_ANALYZE=10
RATE_LIMIT_READ=60

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100

# ── PDF engine ────────────────────────────────────────────────────────────────
# pymupdf (default) | pdfium
PDF_ENGINE=pymupdf

# ── Table extraction engine ──────────────────────────────────────────────────
# auto (pdfplumber, default) | pdfplumber | camelot | best (try all, pick best)
TABLE_ENGINE=auto

# ── Pipeline timeouts ────────────────────────────────────────────────────────
NODE_TIMEOUT_S=120

# ── Debug & observability ─────────────────────────────────────────────────────
# Set to 1 to save intermediate extraction outputs and render page images
DEBUG=0

# ── Market data (P5) ─────────────────────────────────────────────────────────
# dummy (default) | tushare | polygon | yfinance
MARKET_DATA_PROVIDER=dummy
TUSHARE_TOKEN=
POLYGON_API_KEY=
# Cache TTL in seconds (default: 86400 = 24h)
MARKET_CACHE_TTL=86400

# ── Observability (P7) ───────────────────────────────────────────────────────
# OpenTelemetry OTLP endpoint (leave blank to disable tracing)
OTLP_ENDPOINT=
